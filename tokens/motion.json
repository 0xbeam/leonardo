{
  "easing": {
    "--ease-smooth": "cubic-bezier(0.22, 1, 0.36, 1)",
    "--ease-snappy": "cubic-bezier(0.16, 1, 0.3, 1)"
  },
  "keyframes": {
    "pulse-dot": {
      "0%, 100%": "opacity: 0.3",
      "50%": "opacity: 1"
    },
    "slide-in": {
      "from": "opacity: 0; transform: translateY(8px)",
      "to": "opacity: 1; transform: translateY(0)"
    },
    "view-fade": {
      "from": "opacity: 0",
      "to": "opacity: 1"
    },
    "shimmer": {
      "0%": "background-position: -200% 0",
      "100%": "background-position: 200% 0"
    }
  },
  "animations": {
    "pulse-dot": "pulse-dot 2s ease-in-out infinite",
    "slide-in": "slide-in 0.25s var(--ease-smooth) forwards",
    "view-fade": "view-fade 0.2s ease forwards",
    "shimmer": "shimmer 1.5s infinite"
  },
  "transitions": {
    "interactive": "all 0.2s ease",
    "card-hover-transform": "transform 0.2s var(--ease-smooth), box-shadow 0.2s ease",
    "row-hover": "padding-left 0.2s var(--ease-smooth), background-color 0.2s ease"
  }
}